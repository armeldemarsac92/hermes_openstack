cloud                  = "tenant"
cluster_name           = "hermes-test"
cluster_template_name  = "k8s-capi-helm-ubuntu-v1.34.7"
magnum_image_name      = "ubuntu-jammy-kube-v1.34.7"
public_network_name    = "public"
worker_flavor          = "m1.medium"
master_flavor          = "m1.medium"
gemma_nodegroup_name   = "gemma4-large"
gemma_worker_flavor    = "m1.2xlarge"
gemma_worker_count     = 1
master_count           = 1
node_count             = 1
cluster_create_timeout = 90
keypair_name           = "hermes-test-key"
kubernetes_namespace   = "hermes"
storage_class_name     = "lvm"
ollama_data_size       = "40Gi"
gemma_model            = "gemma4:26b"
gemma_context_tokens   = 262144
hermes_image           = "nousresearch/hermes-agent:latest"
hermes_data_size       = "10Gi"
hermes_dashboard_port  = 9119
hermes_dashboard_public_port = 80
hermes_api_port        = 8642
hermes_api_server_model_name = "hermes-agent"
hermes_dashboard_loadbalancer_enabled = true
